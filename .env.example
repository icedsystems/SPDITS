# ============================================================
# ICED SPDITS — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Django
DJANGO_SECRET_KEY=your-very-long-secret-key-here-change-this
DJANGO_SETTINGS_MODULE=config.settings.production
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com

# Database
DATABASE_URL=postgres://spdits_user:spdits_password@db:5432/spdits_db

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Microsoft Azure Entra ID (OAuth)
AZURE_AD_CLIENT_ID=your-azure-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret
AZURE_AD_TENANT_ID=your-azure-tenant-id

# Email — Microsoft Graph API (no SMTP required)
# The licensed mailbox in your Azure tenant with Mail.Send application permission
GRAPH_MAIL_SENDER=info@iced-eval.org
DEFAULT_FROM_EMAIL=ICED SPDITS <info@iced-eval.org>
ADMIN_EMAIL=admin@iced-eval.org

# SFTP
SFTP_HOST=sftp
SFTP_PORT=22
SFTP_ROOT=/home/sftpusers
SFTP_POLL_INTERVAL=60

# Field-level encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
FIELD_ENCRYPTION_KEY=your-fernet-encryption-key-here

# App
APP_URL=https://your-domain.com
INVITATION_EXPIRY_HOURS=1
MAX_UPLOAD_SIZE_MB=100

# Sentry (optional)
SENTRY_DSN=
